{
  "name": "colisgui",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "api:dev": "npm --workspace apps/api run start:dev",
    "api:build": "npm --workspace apps/api run build",
    "web:dev": "npm --workspace apps/web run dev"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^5.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.15"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcrypt": "^5.1.1"
  }
}