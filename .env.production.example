# === Production — à renseigner impérativement ===
NODE_ENV=production

# Postgres (compose)
POSTGRES_USER=colisgui
POSTGRES_PASSWORD=CHANGER_MOI_MOT_DE_PASSE_FORT
POSTGRES_DB=colisgui

# Secrets JWT — générez des valeurs aléatoires (ex. openssl rand -hex 48)
JWT_SECRET=REMPLACER_PAR_SECRET_ALEATOIRE
JWT_REFRESH_SECRET=REMPLACER_PAR_AUTRE_SECRET_ALEATOIRE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — domaines autorisés (séparés par des virgules), PAS de * en prod
CORS_ORIGINS=https://app.colisgui.gn

# Compte directeur initial (seed)
ADMIN_TELEPHONE=627159898
ADMIN_PASSWORD=CHANGER_A_LA_PREMIERE_CONNEXION

# Intégrations (optionnelles)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=
# OM_CLIENT_ID=
# OM_CLIENT_SECRET=
# OM_MERCHANT_KEY=
# OM_NOTIF_TOKEN=secret-partage-webhook-orange-money
